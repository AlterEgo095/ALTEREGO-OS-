# ===== ALTEREGO OS — Environment configuration =====
# Copy this file to `.env` and fill in your values.

# ---- LLM (at least one of OPENAI_API_KEY or OLLAMA_BASE_URL) ----
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Local Ollama (alternative to OpenAI)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# LiteLLM (optional — for multi-provider routing, V2)
# LITELLM_BASE_URL=http://localhost:4000

# ---- Memory (V1: SQLite) ----
ALTEREGO_DB_PATH=./data/alterego.db

# ---- GitHub ----
GITHUB_TOKEN=ghp_...

# ---- Docker (uses local Docker socket by default) ----
# DOCKER_HOST=unix:///var/run/docker.sock

# ---- SSH (used by ssh plugin) ----
# SSH keys are read from ~/.ssh/ by default

# ---- PostgreSQL ----
POSTGRES_DSN=postgresql://user:pass@localhost:5432/dbname

# ---- MongoDB ----
MONGO_URI=mongodb://localhost:27017

# ---- Email (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=...
SMTP_FROM=you@example.com

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# ---- Kernel ----
ALTEREGO_LOG_LEVEL=INFO
ALTEREGO_VALIDATION_STRICT=true
